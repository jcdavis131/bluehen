# ---- Postgres (local: docker compose -f infra/docker-compose.yml up -d) ----
DATABASE_URL=postgresql+psycopg://synth:synth@localhost:5433/synthaembed

# ---- Core API ----
REDIS_URL=redis://localhost:6379/0
API_SECRET_KEY=change-me-32-bytes-min
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=info

# ---- Multi-tenant / auth ----
JWT_ISSUER=synthaembed
JWT_AUDIENCE=synthaembed-api
# Postgres Row-Level Security tenant claim key
TENANT_CLAIM=workspace_id

# ---- Agent models (free / open / local-first) ----
# Local-first: run Ollama, then point agents at its OpenAI-compatible endpoint.
SYNTH_LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # Ollama; unset to use Vercel AI Gateway
SYNTH_LOCAL_LLM_API_KEY=ollama
SYNTH_AGENT_MODEL=qwen3                               # director model (local id or gateway id)
SYNTH_WORKER_MODEL=qwen3                              # smaller/cheaper model for subagents
# Max-quality open-weights option (served, not workstation-local): kimi-k2.6

# ---- Auto-research loop ----
RESEARCH_MAX_CONCURRENT_JOBS=2
RESEARCH_COST_CEILING_USD_PER_DAY=50

# ---- Phase A+ closed loop (Spec 0012) ----
SYNTH_CHARTER_GATE=1                 # 1 = require config/recipes/{siteId}.json before deploy
# BD_QUEUE_PATH=                    # override default content/fleet/bd/queue.json
# RECIPES_DIR=                      # override default config/recipes

# ---- Unified access layer ----
SYNTH_API_BASE_URL=http://localhost:8000
SYNTH_API_KEY=
SYNTH_ACTOR=cli

# ---- Trainer ----
TRAINER_DEVICE=cuda                # cuda | cpu | mps
MODEL_REGISTRY_URI=               # s3://bucket/synthaembed-artifacts (optional; local disk if empty)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_ENDPOINT_URL=                  # optional — Cloudflare R2 / MinIO
WANDB_API_KEY=

# ---- Vector store ----
VECTOR_BACKEND=pgvector            # pgvector | qdrant
QDRANT_URL=

# ---- Web (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Cross-site nav in FleetShell → localhost ports (hub :3000, dumbmodel :3001, …)
NEXT_PUBLIC_FLEET_LOCAL=1
